# .env_modelo
# Este archivo sirve como plantilla. Cópialo y renómbralo a ".env"
# Luego completa los valores con tus credenciales locales

SECRET_KEY=tu-clave-secreta-aqui
DEBUG=True
DB_NAME=nombre_de_tu_base_de_datos
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_HOST=localhost
DB_PORT=3306